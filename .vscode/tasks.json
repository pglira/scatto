{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build & install",
            "type": "shell",
            "command": "make install",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": "$rustc"
        }
    ]
}
